{
  "name": "model-cost",
  "version": "0.0.4",
  "description": "Compare LLM API pricing from your terminal. Supports 300+ models across all major providers.",
  "type": "module",
  "bin": {
    "model-cost": "dist/cli.js",
    "modelcost": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "release": "changeset publish",
    "version": "changeset version",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "llm",
    "pricing",
    "cost",
    "ai",
    "model",
    "openai",
    "anthropic",
    "claude",
    "gpt",
    "gemini",
    "deepseek",
    "cli",
    "compare",
    "tokens"
  ],
  "author": {
    "name": "Saqib Ameen",
    "url": "https://x.com/saqibameen"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saqibameen/model-cost.git"
  },
  "bugs": {
    "url": "https://github.com/saqibameen/model-cost/issues"
  },
  "homepage": "https://github.com/saqibameen/model-cost#readme",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1"
  }
}
